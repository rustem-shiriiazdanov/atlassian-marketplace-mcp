# Atlassian Marketplace API credentials (Basic auth)
ATLASSIAN_EMAIL=you@example.com
ATLASSIAN_API_TOKEN=your_api_token_here

# Vendor identifiers — these are different for the two API surfaces
# DEVELOPER_ID is used by the v3 reporting endpoints (licenses, transactions)
# PARTNER_ID is used by the v1 promotions endpoints
# Both can be resolved via GET /rest/3/developer-space/vendor/{vendorId}
MARKETPLACE_DEVELOPER_ID=
MARKETPLACE_PARTNER_ID=

# Known product IDs (optional). Any env var matching PRODUCT_ID_<NAME> is
# picked up by the apps_known tool and exposed as a friendly name -> UUID map.
# productId is a UUID, not an app key. Use apps_list to discover them.
# Example:
# PRODUCT_ID_YOUR_APP=00000000-0000-0000-0000-000000000000
